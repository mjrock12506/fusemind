# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# Groq (free tier) — used Phase 4+ for LLM + Whisper STT
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# Supabase (free tier) — used Phase 2+ for persistence
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Whoop (your subscription) — used Phase 5
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
